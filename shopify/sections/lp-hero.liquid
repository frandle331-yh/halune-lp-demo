{% comment %}
  LP用ヒーローセクション(商品紹介)
  - テーマカスタマイザーから商品・見出し・バッジを編集可能
  - OS 2.0対応(templates/page.lp.json から呼び出し)
{% endcomment %}

{{ 'lp-styles.css' | asset_url | stylesheet_tag }}

<section class="lp-hero" id="top">
  <div class="lp-hero__inner">
    <div class="lp-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lp-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="lp-hero__title">{{ section.settings.title }}</h1>
      {%- if section.settings.lead != blank -%}
        <p class="lp-hero__lead">{{ section.settings.lead }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="lp-hero__badges">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <span class="lp-hero__badge" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- assign product = section.settings.product -%}
      {%- if product != blank -%}
        {%- assign variant = product.selected_or_first_available_variant -%}
        {%- comment -%} カート直行:/cart/{variant_id}:{quantity} パーマリンク {%- endcomment -%}
        <a class="lp-btn-primary" href="{{ routes.cart_add_url }}?id={{ variant.id }}&quantity=1">
          {{ section.settings.cta_label | default: '今すぐ購入する' }}<span class="arrow">→</span>
        </a>
      {%- else -%}
        <a class="lp-btn-primary" href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label | default: '今すぐ購入する' }}<span class="arrow">→</span>
        </a>
      {%- endif -%}

      {%- if section.settings.note != blank -%}
        <p class="lp-hero__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>

    <div class="lp-hero__visual">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'eager',
            widths: '400, 600, 900',
            sizes: '(max-width: 820px) 70vw, 420px',
            alt: section.settings.image.alt | default: product.title }}
      {%- elsif product != blank -%}
        {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'eager', alt: product.title }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LP:ヒーロー(商品紹介)",
  "tag": "section",
  "class": "lp-section-hero",
  "settings": [
    { "type": "product", "id": "product", "label": "販売商品" },
    { "type": "image_picker", "id": "image", "label": "メインビジュアル(未設定時は商品画像)" },
    { "type": "text", "id": "eyebrow", "label": "アイキャッチ(小見出し)", "default": "導入美容液 ─ MOIST GLOW SERUM" },
    { "type": "textarea", "id": "title", "label": "メインコピー", "default": "洗顔後すぐの一滴が、その先のうるおいを変える。" },
    { "type": "textarea", "id": "lead", "label": "リード文" },
    { "type": "text", "id": "cta_label", "label": "CTAボタンのラベル", "default": "今すぐセール価格で試す" },
    { "type": "url", "id": "cta_link", "label": "CTAリンク(商品未選択時のフォールバック)" },
    { "type": "text", "id": "note", "label": "注記(※表記など)" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "バッジ",
      "settings": [
        { "type": "text", "id": "label", "label": "ラベル", "default": "パラベンフリー" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "LP:ヒーロー(商品紹介)",
      "blocks": [
        { "type": "badge", "settings": { "label": "合成香料フリー" } },
        { "type": "badge", "settings": { "label": "パラベンフリー" } },
        { "type": "badge", "settings": { "label": "国内製造" } }
      ]
    }
  ]
}
{% endschema %}
